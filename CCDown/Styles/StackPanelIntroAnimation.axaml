<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cc="http://ccdown.lrsgzs.top/schemas/xaml/core">
    <Design.PreviewWith>
        <Border Padding="20">
            <!-- Add Controls for Previewer Here -->
        </Border>
    </Design.PreviewWith>

    <!-- Add Styles Here -->
    <Style Selector=":is(Panel).animated-intro">
        <Setter Property="cc:StackPanelIntroAnimationBehavior.IsIntroAnimationEnabled" Value="True" />
        <Style Selector="^> :is(Control)[(cc|StackPanelIntroAnimationBehavior.CanPlayAnimation)=True]">
            <Setter Property="Opacity" Value="0" />
            <Setter Property="RenderTransform">
                <Setter.Value>
                    <TranslateTransform Y="-25" />
                </Setter.Value>
            </Setter>
            <Style Selector="^[(cc|StackPanelIntroAnimationBehavior.IsAnimationPlayed)=True]">
                <Style.Animations>
                    <Animation Duration="0:0:0.75" FillMode="Both" Easing="0.00, 1.00, 0.00, 1.00">
                        <KeyFrame Cue="0%">
                            <Setter Property="TranslateTransform.Y" Value="50" />
                            <Setter Property="Opacity" Value="0" />
                        </KeyFrame>
                        <KeyFrame Cue="100%">
                            <Setter Property="TranslateTransform.Y" Value="0" />
                            <Setter Property="Opacity" Value="1" />
                        </KeyFrame>
                    </Animation>
                </Style.Animations>
            </Style>
        </Style>
    </Style>
</Styles>