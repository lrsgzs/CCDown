<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cc="http://ccdown.lrsgzs.top/schemas/xaml/core"
        xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia">
    <Design.PreviewWith>
        <cc:Empty />
    </Design.PreviewWith>

    <Style Selector="cc|Empty">
        <!-- Set Defaults -->
        <Setter Property="Template">
            <ControlTemplate>
                <StackPanel Spacing="8" VerticalAlignment="Center" HorizontalAlignment="Center">
                    <fa:FAIconSourceElement IconSource="{TemplateBinding Icon}"
                                            Height="{TemplateBinding IconHeight}"
                                            Width="{TemplateBinding IconWidth}"
                                            HorizontalAlignment="Center" />
                    <TextBlock Text="{TemplateBinding Text}" HorizontalAlignment="Center"
                               TextAlignment="Center" TextWrapping="Wrap" />
                </StackPanel>
            </ControlTemplate>
        </Setter>
    </Style>
</Styles>