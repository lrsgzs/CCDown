<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cc="http://ccdown.lrsgzs.top/schemas/xaml/core">
    <Design.PreviewWith>
        <cc:FluentIcon />
    </Design.PreviewWith>

    <Style Selector="cc|FluentIcon">
        <Setter Property="FontFamily" Value="{DynamicResource FluentSystemIconsResizeable}" />
    </Style>
</Styles>