<ResourceDictionary xmlns="https://github.com/avaloniaui"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:cc="http://ccdown.lrsgzs.top/schemas/xaml/core">
    <ControlTemplate x:Key="DevelopmentBuildAdornerControlTemplate"
                     TargetType="cc:DevelopmentBuildAdorner">
        <Grid VerticalAlignment="Stretch"
              IsHitTestVisible="False"
              HorizontalAlignment="Stretch">
            <TextBlock VerticalAlignment="Bottom"
                       HorizontalAlignment="Left"
                       TextAlignment="Left"
                       FontSize="12"
                       Opacity="0.8">
                开发中画面，不代表最终品质。<LineBreak />
                CCDown
                <Run Text="{x:Static cc:GlobalConstants.VersionLong}" />
            </TextBlock>
        </Grid>
    </ControlTemplate>

    <ControlTheme TargetType="cc:DevelopmentBuildAdorner"
                  x:Key="{x:Type cc:DevelopmentBuildAdorner}">
        <Setter Property="Template" Value="{StaticResource DevelopmentBuildAdornerControlTemplate}" />
    </ControlTheme>
</ResourceDictionary>