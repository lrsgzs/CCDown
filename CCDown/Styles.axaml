<Styles xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:cc="http://ccdown.lrsgzs.top/schemas/xaml/core"
        xmlns:fa="clr-namespace:FluentAvalonia.UI.Controls;assembly=FluentAvalonia"
        xmlns:styling="clr-namespace:FluentAvalonia.Styling;assembly=FluentAvalonia"
        xmlns:system="clr-namespace:System;assembly=System.Runtime"
        xmlns:asyncImageLoader="clr-namespace:AsyncImageLoader;assembly=AsyncImageLoader.Avalonia">
    <Styles.Resources>
        <ResourceDictionary>
            <ResourceDictionary.MergedDictionaries>
                <MergeResourceInclude Source="/Styles/ChipListBox.axaml" />
                <MergeResourceInclude Source="/Controls/DevelopmentBuildAdorner.axaml" />
            </ResourceDictionary.MergedDictionaries>

            <system:Double x:Key="PageContainerWidth">960</system:Double>
        </ResourceDictionary>
    </Styles.Resources>
    
    <styling:FluentAvaloniaTheme UseSystemFontOnWindows="False"
                                 PreferUserAccentColor="False"
                                 CustomAccentColor="#07c160"
                                 TextVerticalAlignmentOverrideBehavior="Disabled" />

    <StyleInclude Source="/Styles/NavigationBackButton.axaml" />
    <StyleInclude Source="/Styles/PopupAnimations.axaml" />
    <StyleInclude Source="/Styles/StackPanelIntroAnimation.axaml" />
    <StyleInclude Source="/Styles/TabStrip.axaml" />
    <StyleInclude Source="/Controls/StickyScrollViewer.axaml" />
    <StyleInclude Source="/Controls/Empty.axaml" />
    <StyleInclude Source="/Controls/Emptiable.axaml" />
    <StyleInclude Source="/Controls/Field.axaml" />
    
    <Style Selector=":is(Window)">
        <Setter Property="FontFamily" Value="{DynamicResource AppFontFamily}" />
    </Style>
    
    <Style Selector="TextBlock :is(HyperlinkButton)">
        <Setter Property="Padding" Value="0" />
        <Setter Property="Margin" Value="0 0 0 -4" />
        <Setter Property="TextBlock.LineHeight" Value="NaN" />
        <Style Selector="^ TextBlock">
            <!-- 修复字体飞上去的问题 -->
            <Setter Property="Margin" Value="0 0 0 -2" />
        </Style>
    </Style>

    <Style Selector="ToggleSwitch">
        <Setter Property="OnContent" Value="" />
        <Setter Property="OffContent" Value="" />
    </Style>
    
    <Style Selector="StackPanel.page-container">
        <Setter Property="Margin" Value="15 12 15 12" />
        <Setter Property="MaxWidth" Value="{StaticResource PageContainerWidth}" />
        <Setter Property="Spacing" Value="4" />
    </Style>

    <Style Selector="asyncImageLoader|AdvancedImage">
        <Setter Property="Template">
            <ControlTemplate>
                <Grid x:Name="Root"
                      Classes.empty="{TemplateBinding CurrentImage, Converter={x:Static ObjectConverters.IsNull}, Mode=OneWay}">
                    <cc:FluentIcon VerticalAlignment="Center" HorizontalAlignment="Center"
                                   Glyph="&#xE9CC;"
                                   IsVisible="False" IsHitTestVisible="False"
                                   x:Name="FluentIconError"
                                   FontSize="18"
                                   Foreground="{DynamicResource SystemFillColorCriticalBrush}" />
                </Grid>
            </ControlTemplate>
        </Setter>

        <Style Selector="^[IsLoading=False] /template/ Grid#Root.empty">
            <Style Selector="^ Border#LoadingBorder">
                <Setter Property="IsVisible" Value="True" />
                <Setter Property="Background" Value="{DynamicResource SystemFillColorCriticalBackgroundBrush}" />
                <Setter Property="ToolTip.Tip" Value="喔唷，图裂啦" />
            </Style>
            <Style Selector="^ cc|FluentIcon#FluentIconError">
                <Setter Property="IsVisible" Value="True" />
            </Style>
        </Style>
    </Style>

    <Style Selector="Carousel.animated">
        <Setter Property="PageTransition">
            <Setter.Value>
                <CompositePageTransition>
                    <PageSlide Duration="0:0:0.3" Orientation="Horizontal"
                               SlideOutEasing="0.76, 0, 0.24, 1"
                               SlideInEasing="0.76, 0, 0.24, 1" />
                    <CrossFade Duration="0:0:0.3" />
                </CompositePageTransition>
            </Setter.Value>
        </Setter>
    </Style>
    
    <Style Selector="TabControl.compact TabItem">
        <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="TextElement.FontSize" Value="14" />
            <Setter Property="TextElement.FontWeight" Value="Medium" />
        </Style>
        <Setter Property="MinHeight" Value="28" />
    </Style>

    <Style Selector="TabStrip.compact TabStripItem">
        <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
            <Setter Property="TextElement.FontSize" Value="14" />
            <Setter Property="TextElement.FontWeight" Value="Medium" />
        </Style>
        <Setter Property="MinHeight" Value="28" />
    </Style>

    <Style Selector="Expander.compact">
        <Setter Property="Padding" Value="8" />
        <Style Selector="^ /template/ ToggleButton#ExpanderHeader">
            <Setter Property="MinHeight" Value="36" />
        </Style>
        <Style Selector="^ /template/ ToggleButton#ExpanderHeader /template/ Border#Root">
            <Setter Property="Padding" Value="8 0 0 0" />
        </Style>
        <Style Selector="^ /template/ ToggleButton#ExpanderHeader /template/ Border#ExpandCollapseChevronBorder">
            <Setter Property="Margin" Value="4,-8,8,-8" />
        </Style>
    </Style>

    <Style
        Selector="Expander.stretch-header /template/ ToggleButton#ExpanderHeader /template/ ContentPresenter#ContentPresenter">
        <Setter Property="HorizontalAlignment" Value="Stretch" />
        <Setter Property="HorizontalContentAlignment" Value="Stretch" />
    </Style>

    <Style Selector="fa|FASettingsExpanderItem">
        <Style Selector="^ ToggleSwitch">
            <Setter Property="Margin" Value="0 -12" />
            <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="IsVisible" Value="False" />
            </Style>
        </Style>
        <Style Selector="^ Slider">
            <Setter Property="Margin" Value="0 -12" />
        </Style>
    </Style>

    <Style
        Selector="fa|FACommandBar.hide-popup-indicator fa|FACommandBarButton:labelright /template/ fa|FAFontIcon#SubItemChevron">
        <Setter Property="IsVisible" Value="False" />
    </Style>
</Styles>
